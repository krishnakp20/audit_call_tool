APP_NAME=Call Audit SaaS
APP_ENV=development
DEBUG=true
APP_HOST=0.0.0.0
APP_PORT=8000

SECRET_KEY=replace-with-secure-key
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=1440

MYSQL_USER=root
MYSQL_PASSWORD=root
MYSQL_HOST=localhost
MYSQL_PORT=3306
MYSQL_DB=call_audit

REDIS_URL=redis://localhost:6379/0
CELERY_BROKER_URL=redis://localhost:6379/1
CELERY_RESULT_BACKEND=redis://localhost:6379/2

CORS_ORIGINS=["http://localhost:5173"]

# Deepgram STT
STT_API_URL=https://api.deepgram.com/v1/listen
STT_API_KEY=
STT_MOCK_ENABLED=false
STT_MODEL=nova
STT_LANGUAGE=hi-Latn

# LLM (prefer OPENAI_API_KEY when no custom LLM endpoint)
LLM_API_URL=https://llm.example.com/audit
LLM_API_KEY=
LLM_MOCK_ENABLED=false
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o
